# ─────────────────────────────────────────────────────────────────
# Amenify Chatbot — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────
# HOW TO USE:
#   Local:      Copy this file to .env and fill in your real values
# ─────────────────────────────────────────────────────────────────

# ── Groq API (LLM Generation) ─────────────────────────────────────
# Required. Get a FREE key at https://console.groq.com
# Free tier: 14,400 requests/day, 6,000 tokens/min — no credit card needed.
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Model ─────────────────────────────────────────────────────────
# llama-3.3-70b-versatile: best quality on Groq's free tier
# Alternatives: llama-3.1-8b-instant (faster), mixtral-8x7b-32768
CHAT_MODEL=llama-3.3-70b-versatile

# ── Retrieval Tuning ──────────────────────────────────────────────
# TOP_K: number of chunks to retrieve and pass to the LLM (default 4)
TOP_K=4

# CONFIDENCE_THRESHOLD: minimum TF-IDF cosine similarity score (0–1).
# Chunks below this score are discarded. For TF-IDF on a small domain
# corpus, scores are typically 0.005–0.08. Do not set above 0.02.
CONFIDENCE_THRESHOLD=0.005

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# LOCAL:      http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
