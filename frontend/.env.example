# ─────────────────────────────────────────────────────────────────
# Amenify Chatbot — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────
# HOW TO USE:
#   Local:  Copy this file to .env.local and set the backend URL
#   Vercel: Add VITE_API_URL in Project Settings → Environment Variables
#
# NEVER commit .env.local — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────
# LOCAL:      Leave as-is or set to http://localhost:8000
# PRODUCTION: Set to your deployed Render backend URL
#
# If VITE_API_URL is not set, the app automatically falls back to
# http://localhost:8000 (safe for local development).
#
# Example: VITE_API_URL=https://amenify-chatbot-api.onrender.com
VITE_API_URL=https://your-render-service.onrender.com
